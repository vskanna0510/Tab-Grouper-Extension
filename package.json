{
  "name": "tabsense-extension",
  "version": "1.0.0",
  "description": "TabSense - a context-aware tab manager Chrome Extension (Manifest V3)",
  "private": true,
  "scripts": {
    "dev": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "build:css": "tailwindcss -i ./src/popup/styles.css -o ./public/popup.css --minify",
    "build:all": "npm run build && npm run build:css"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^9.1.3",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.17",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
